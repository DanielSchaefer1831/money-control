<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyControl.DashboardPage"
             Title=""
             NavigationPage.HasNavigationBar="False"
             NavigationPage.HasBackButton="False">

    <ScrollView>
    <VerticalStackLayout Padding="20">

        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="10">

            <!-- Welcome label with user name -->
            <HorizontalStackLayout Grid.Column="0" Grid.Row="0" VerticalOptions="Center">
                <Label Text="Hallo, " FontSize="22" TextColor="Gray"/>
                <Label x:Name="lblHelloUsername"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="Black"/>
            </HorizontalStackLayout>

            <!-- Delete account button -->
                <Button Grid.Column="1" Grid.Row="0"
                        Text="Account löschen"
                        TextColor="White"
                        BackgroundColor="#D32F2F" 
                        CornerRadius="25"
                        FontSize="12"
                        FontAttributes="Bold"
                        Clicked="OnDeleteAccountClicked"/>

                <!-- Logout button -->
                <Button Grid.Column="1" Grid.Row="1"
                        Text="Abmelden"
                        BackgroundColor="#FF6B6B" 
                        TextColor="White"
                        CornerRadius="25"
                        HorizontalOptions="End"
                        Clicked="OnLogoutClicked" />

            </Grid>

        <!-- Spending area -->
        <Frame BackgroundColor="#F8F9FA"
               BorderColor="#3498DB"
               CornerRadius="15"
               Margin="0, 10"
               HasShadow="True">
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="Ausgaben diesen Monat"
                       TextColor="Gray"
                       FontSize="15"/>
                <Label x:Name="lblTotalExpenses"
                       Text="0,00€"
                       TextColor="#2C3E50"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>
        
        <!-- New expenses -->
        <Frame CornerRadius="15" Padding="20" BackgroundColor="White" HasShadow="True">
            <VerticalStackLayout Spacing="15">
                <Label Text="NEUE AUSGABE:" FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#3498DB"/>

                <Entry x:Name="entAmount"
                       Placeholder="Betrag:"
                       Keyboard="Text"
                       FontSize="18"/>

                <Entry x:Name="entDescription"
                       Placeholder="Grund:"
                       FontSize="16"/>

                <Picker x:Name="picCategory"
                        Title="Kategorie wählen:"
                        FontSize="16">
                    <Picker.Items>
                        <x:String>🍎 Lebensmittel</x:String>
                        <x:String>🚗 Auto / Transport</x:String>
                        <x:String>🎉 Spaß / Freizeit</x:String>
                        <x:String>🏠 Wohnen / Miete</x:String>
                        <x:String>👔 Kleidung</x:String>
                        <x:String>❓ Sonstiges</x:String>
                    </Picker.Items>
                </Picker>

                <Button Text="Ausgabe hinzufügen"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        Clicked="OnAddEntryClicked"/>
            </VerticalStackLayout>
        </Frame>

        <Label Text="Deine letzten Ausgaben" 
               FontSize="18" 
               FontAttributes="Bold" 
               Margin="0,20,0,5" />

        <!-- Design for expenses -->    
        <CollectionView x:Name="lstExpenses" Margin="0,0,0,20">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItem Text="Löschen"
                                               BackgroundColor="Red"
                                               Invoked="OnDeleteExpenseInvoked"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame CornerRadius="10" Margin="0,5" Padding="12" BackgroundColor="White" HasShadow="False" BorderColor="#EEEEEE">
                                <Grid ColumnDefinitions="40, *, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="10">

                                    <Label Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" 
                                           Text="{Binding Category}" 
                                           FontSize="26" 
                                           VerticalOptions="Center" 
                                           HorizontalOptions="Center"
                                           LineBreakMode="NoWrap"
                                           WidthRequest="40"/>

                                    <Label Grid.Column="1" Grid.Row="0" 
                                           Text="{Binding Description}" 
                                           FontAttributes="Bold" 
                                           FontSize="16" 
                                           TextColor="#2C3E50"
                                           LineBreakMode="TailTruncation"/>

                                    <Label Grid.Column="1" Grid.Row="1" 
                                           Text="{Binding Date, StringFormat='{0:dd.MM.yyyy HH:mm}'}" 
                                           FontSize="12" 
                                           TextColor="Gray"/>

                                    <Label Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" 
                                           Text="{Binding Amount, StringFormat='{0:F2} €'}" 
                                           TextColor="#E74C3C" 
                                           FontAttributes="Bold" 
                                           VerticalOptions="Center" 
                                           FontSize="18"
                                           Margin="5,0,0,0"/>
                                </Grid>
                            </Frame>

                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>    
</ContentPage>