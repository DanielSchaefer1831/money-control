<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MoneyControl.MainPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <!--<Image Source="hausbuch.jpg" 
           Aspect="AspectFill"
           HorizontalOptions="Fill"
           VerticalOptions="Fill" />-->

        <!-- Background from the app -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4A90E2" Offset="0.0"/>
                <GradientStop Color="#C2E0FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <VerticalStackLayout Margin="20, 40, 20, 0" Spacing="25">

                <!-- MC-Logo -->
                <Image Source="mc_logo2.png"
                       HeightRequest="180"
                       WidthRequest="180"/>

                <!-- Welcome-Label -->
                <Label x:Name="lblWelcomeToTheApp"
                       Text="Willkommen bei MoneyControl!"
                       HorizontalOptions="Center"
                       FontSize="20"
                       FontAttributes="Bold"/>

                <!-- Login-Label -->
                <Label x:Name="lblLogin" 
                       Text="Anmeldung" 
                       FontSize="40" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center"/>

                <!-- Username-Input -->
                <Border x:Name="brdUsername"
                        Stroke="Gray"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 25"
                        BackgroundColor="LightGray"
                        Padding="15,0,5,0">
                    <Grid ColumnDefinitions="30, *">
                        <Image Grid.Column="0"
                               x:Name="imgUserProfile"
                               Source="benutzerprofil.png"
                               HeightRequest="30"
                               WidthRequest="30"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>

                        <Entry x:Name="entUsername"
                               Grid.Column="1"
                               Placeholder="Benutzername"
                               PlaceholderColor="Black"
                               FontSize="15"
                               Margin="5,5,0,5"/>
                    </Grid>
                </Border>

                <!-- Password-Input -->
                <Border x:Name="brdPassword"
                        Stroke="Gray"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 25"
                        BackgroundColor="LightGray"
                        Padding="15, 5, 10, 5">
                    <Grid ColumnDefinitions="*, 35">
                        <Entry x:Name="entPassword"
                               Grid.Column="0"
                               Placeholder="Passwort"
                               IsPassword="False"
                               PlaceholderColor="Black"
                               FontSize="15"/>

                        <ImageButton x:Name="btnImageChangePassword"
                                     Grid.Column="1"
                                     Source="show.png"
                                     HeightRequest="30"
                                     WidthRequest="30"
                                     VerticalOptions="Center"
                                     Clicked="PasswordImage"/>
                    </Grid>
                </Border>

                <!-- Login-Button -->
                <Button x:Name="btnLogin"
                        Text="Anmelden"
                        FontSize="15"
                        CornerRadius="25"
                        BorderColor="Gray"
                        BorderWidth="2"
                        HeightRequest="55"
                        Clicked="OnLoginClicked">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#66B2FF" Offset="0.0"/> 
                            <GradientStop Color="#007BFF" Offset="0.33"/> 
                            <GradientStop Color="#0052CC" Offset="0.66"/> 
                            <GradientStop Color="#003366" Offset="1.0"/> 
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Register-Button -->
                <Button x:Name="btnRegister"
                        Text="Account erstellen"
                        FontSize="15"
                        CornerRadius="25"
                        BorderColor="Gray"
                        BorderWidth="2"
                        HeightRequest="55"
                        Clicked="RegisterButton">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#003366" Offset="0.0"/>
                            <GradientStop Color="#0052CC" Offset="0.33"/>
                            <GradientStop Color="#007BFF" Offset="0.66"/>
                            <GradientStop Color="#66B2FF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
